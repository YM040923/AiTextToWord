<Window
    x:Class="AiTextToWord.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="AI 文本转 Word">

    <Grid Background="{ThemeResource LayerFillColorDefaultBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="TitleBarDragRegion"
            Background="Transparent" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

        <Border
            Grid.Column="0"
            Margin="16"
            Padding="18"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="12">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="8">
                    <Border
                        Padding="12,10"
                        Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                        CornerRadius="8">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                FontSize="16"
                                Glyph="&#xE8C8;"
                                Opacity="0.78" />
                            <TextBlock
                                Grid.Column="1"
                                Text="粘贴"
                                VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border
                        Padding="12,10"
                        Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                        CornerRadius="8">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                FontSize="16"
                                Glyph="&#xE9D9;"
                                Opacity="0.78" />
                            <TextBlock
                                Grid.Column="1"
                                Text="整理"
                                VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border
                        Padding="12,10"
                        Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                        CornerRadius="8">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                FontSize="16"
                                Glyph="&#xE74E;"
                                Opacity="0.78" />
                            <TextBlock
                                Grid.Column="1"
                                Text="导出"
                                VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </StackPanel>

                <Border
                    Grid.Row="2"
                    Padding="12"
                    Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="8">
                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="12"
                            Opacity="0.64"
                            Text="状态" />
                        <TextBlock
                            x:Name="StatusText"
                            FontWeight="SemiBold"
                            Text="就绪"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid
            Grid.Column="1"
            Padding="8,16,16,16"
            RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock
                        FontSize="28"
                        FontWeight="SemiBold"
                        Text="工作台" />
                    <TextBlock
                        Opacity="0.66"
                        Text="粘贴来自 ChatGPT、Claude、Copilot 或其他 AI 助手的内容，导出前先预览整理后的结构。" />
                </StackPanel>

                <Button
                    x:Name="ExportButton"
                    Grid.Column="1"
                    Padding="16,8"
                    Click="Export_Click"
                    Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="15" Glyph="&#xE74E;" />
                        <TextBlock x:Name="ExportButtonText" Text="导出 Word" />
                    </StackPanel>
                </Button>
            </Grid>

            <Border
                Grid.Row="1"
                Padding="14"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <StackPanel Spacing="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="导出设置" />
                        <TextBlock
                            x:Name="SettingsSummaryText"
                            Grid.Column="1"
                            Opacity="0.62"
                            Text="标准文档"
                            VerticalAlignment="Center" />
                    </Grid>

                    <Grid ColumnSpacing="10" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Spacing="4">
                            <TextBlock FontSize="12" Opacity="0.68" Text="格式" />
                            <ComboBox
                                x:Name="ExportFormatComboBox"
                                HorizontalAlignment="Stretch"
                                SelectedIndex="0"
                                SelectionChanged="ExportSettings_Changed">
                                <ComboBoxItem Content="Word" />
                                <ComboBoxItem Content="PDF" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock FontSize="12" Opacity="0.68" Text="预设" />
                            <ComboBox
                                x:Name="PresetComboBox"
                                HorizontalAlignment="Stretch"
                                SelectedIndex="0"
                                SelectionChanged="PresetComboBox_SelectionChanged">
                                <ComboBoxItem Content="标准文档" />
                                <ComboBoxItem Content="紧凑笔记" />
                                <ComboBoxItem Content="正式报告" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock FontSize="12" Opacity="0.68" Text="字体" />
                            <AutoSuggestBox
                                x:Name="FontSearchBox"
                                HorizontalAlignment="Stretch"
                                MaxSuggestionListHeight="360"
                                PlaceholderText="搜索字体"
                                QuerySubmitted="FontSearchBox_QuerySubmitted"
                                SuggestionChosen="FontSearchBox_SuggestionChosen"
                                TextChanged="FontSearchBox_TextChanged" />
                        </StackPanel>

                        <StackPanel Grid.Column="3" Spacing="4">
                            <TextBlock FontSize="12" Opacity="0.68" Text="正文字号" />
                            <ComboBox
                                x:Name="BodyFontSizeComboBox"
                                HorizontalAlignment="Stretch"
                                SelectedIndex="1"
                                SelectionChanged="ExportSettings_Changed">
                                <ComboBoxItem Content="10.5" />
                                <ComboBoxItem Content="11" />
                                <ComboBoxItem Content="12" />
                                <ComboBoxItem Content="14" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Spacing="4">
                            <TextBlock FontSize="12" Opacity="0.68" Text="标题字号" />
                            <ComboBox
                                x:Name="HeadingFontSizeComboBox"
                                HorizontalAlignment="Stretch"
                                SelectedIndex="2"
                                SelectionChanged="ExportSettings_Changed">
                                <ComboBoxItem Content="16" />
                                <ComboBoxItem Content="18" />
                                <ComboBoxItem Content="20" />
                                <ComboBoxItem Content="22" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                            <TextBlock FontSize="12" Opacity="0.68" Text="行距" />
                            <ComboBox
                                x:Name="LineSpacingComboBox"
                                HorizontalAlignment="Stretch"
                                SelectedIndex="1"
                                SelectionChanged="ExportSettings_Changed">
                                <ComboBoxItem Content="1.15" />
                                <ComboBoxItem Content="1.3" />
                                <ComboBoxItem Content="1.5" />
                                <ComboBoxItem Content="2.0" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="2" Spacing="4">
                            <TextBlock FontSize="12" Opacity="0.68" Text="页边距" />
                            <ComboBox
                                x:Name="PageMarginComboBox"
                                HorizontalAlignment="Stretch"
                                SelectedIndex="1"
                                SelectionChanged="ExportSettings_Changed">
                                <ComboBoxItem Content="窄" />
                                <ComboBoxItem Content="标准" />
                                <ComboBoxItem Content="宽" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="3" Spacing="4">
                            <TextBlock FontSize="12" Opacity="0.68" Text="引用块" />
                            <ComboBox
                                x:Name="QuoteStyleComboBox"
                                HorizontalAlignment="Stretch"
                                SelectedIndex="0"
                                SelectionChanged="ExportSettings_Changed">
                                <ComboBoxItem Content="普通缩进" />
                                <ComboBoxItem Content="灰色引用块" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Spacing="4">
                            <TextBlock FontSize="12" Opacity="0.68" Text="列表密度" />
                            <ComboBox
                                x:Name="ListDensityComboBox"
                                HorizontalAlignment="Stretch"
                                SelectedIndex="0"
                                SelectionChanged="ExportSettings_Changed">
                                <ComboBoxItem Content="紧凑" />
                                <ComboBoxItem Content="舒展" />
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Grid Grid.Row="2" ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                FontSize="18"
                                Glyph="&#xE8C8;"
                                Opacity="0.8" />
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="原始 AI 文本" />
                                <TextBlock
                                    x:Name="InputMetaText"
                                    Opacity="0.62"
                                    Text="等待粘贴内容" />
                            </StackPanel>
                            <StackPanel
                                Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="8">
                                <Button
                                    Click="Sample_Click"
                                    ToolTipService.ToolTip="填入示例文本">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="14" Glyph="&#xE8A5;" />
                                        <TextBlock Text="示例" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    Click="Paste_Click"
                                    ToolTipService.ToolTip="从剪贴板粘贴">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="14" Glyph="&#xE77F;" />
                                        <TextBlock Text="粘贴" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <TextBox
                            x:Name="InputTextBox"
                            Grid.Row="1"
                            AcceptsReturn="True"
                            BorderThickness="0"
                            FontFamily="Cascadia Mono, Consolas"
                            FontSize="13"
                            Padding="14"
                            PlaceholderText="在这里粘贴 AI 输出内容..."
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            TextChanged="InputTextBox_TextChanged"
                            TextWrapping="Wrap" />
                    </Grid>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Padding="16,16,16,0" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                FontSize="18"
                                Glyph="&#xE9D9;"
                                Opacity="0.8" />
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="整理预览" />
                                <TextBlock
                                    x:Name="PreviewMetaText"
                                    Opacity="0.62"
                                    Text="暂无文档块" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1">
                            <StackPanel
                                x:Name="EmptyPreviewPanel"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="12">
                                <Border
                                    Width="56"
                                    Height="56"
                                    HorizontalAlignment="Center"
                                    Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                                    CornerRadius="16">
                                    <FontIcon
                                        FontSize="24"
                                        Glyph="&#xE8A5;"
                                        Opacity="0.64" />
                                </Border>
                                <TextBlock
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    HorizontalAlignment="Center"
                                    Text="预览会显示在这里" />
                                <TextBlock
                                    Width="280"
                                    HorizontalAlignment="Center"
                                    Opacity="0.64"
                                    Text="粘贴 AI 回复后，可以在这里看到标题、列表、引用和代码块等整理后的文档结构。"
                                    TextAlignment="Center"
                                    TextWrapping="Wrap" />
                            </StackPanel>

                            <ScrollViewer
                                x:Name="PreviewScrollViewer"
                                Padding="24"
                                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                                HorizontalScrollBarVisibility="Disabled"
                                VerticalScrollBarVisibility="Auto"
                                Visibility="Collapsed">
                                <Border
                                    x:Name="PreviewPage"
                                    Width="620"
                                    MinHeight="876"
                                    HorizontalAlignment="Center"
                                    Background="White"
                                    BorderBrush="#18000000"
                                    BorderThickness="1"
                                    CornerRadius="2"
                                    Padding="56"
                                    Visibility="Collapsed">
                                    <StackPanel x:Name="PreviewPanel" />
                                </Border>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Border
                Grid.Row="3"
                Padding="10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Opacity="0.64"
                        Text="本地处理。你的文本只会在这台设备上整理和导出。"
                        VerticalAlignment="Center" />
                    <StackPanel
                        Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8">
                        <Button Click="Clear_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="14" Glyph="&#xE894;" />
                                <TextBlock Text="清空" />
                            </StackPanel>
                        </Button>
                        <Button Click="Paste_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="14" Glyph="&#xE77F;" />
                                <TextBlock Text="粘贴" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Grid>
</Window>
